# Network
HNM_HOST=0.0.0.0
HNM_PORT=8787

# Runtime directories
HNM_DATA_DIR=./data
HNM_MODEL_DIR=./models
HNM_VOG_DIR=./vendor/SwinUNet-VOG

# Optional: if vertiwisdom.py lives outside HNM_VOG_DIR, provide colon-separated paths
# HNM_VOG_MODULE_PATHS=/opt/hnm/vog:/srv/shared/vog

# Optional: override checkpoint file directly
# VOG_CHECKPOINT_PATH=/opt/hnm/models/checkpoint_best.pth

# Offline deployment profile
HNM_DEPLOY_PROFILE=gpu-cu126

# Service process settings
HNM_WORKERS=1
HNM_LOG_DIR=./logs
HNM_RUN_DIR=./run
HNM_VENV_DIR=./.venv-hospital
