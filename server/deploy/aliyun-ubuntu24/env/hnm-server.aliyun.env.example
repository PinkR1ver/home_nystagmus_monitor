# Bind
HNM_HOST=0.0.0.0
HNM_PORT=8787

# Layout
HNM_DATA_DIR=/opt/hnm/data
HNM_MODEL_DIR=/opt/hnm/server/models
HNM_VOG_DIR=/opt/hnm/server/vendor/SwinUNet-VOG
HNM_LOG_DIR=/opt/hnm/logs
HNM_RUN_DIR=/opt/hnm/run
HNM_VENV_DIR=/opt/hnm/server/.venv-aliyun

# Optional: if vertiwisdom.py is not directly inside HNM_VOG_DIR
# HNM_VOG_MODULE_PATHS=/opt/hnm/server/vendor/SwinUNet-VOG

# Optional: direct checkpoint override
# VOG_CHECKPOINT_PATH=/opt/hnm/server/models/checkpoint_best.pth

# Runtime
HNM_DEPLOY_PROFILE=gpu-cu126
HNM_WORKERS=1

# Python and pip
PYTHON_BIN=python3.12
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_TRUSTED_HOST=mirrors.aliyun.com

# Optional torch sources, preferred order:
# 1) local wheelhouse
# TORCH_WHEELHOUSE=/opt/hnm/wheelhouse
# 2) domestic torch index
# TORCH_INDEX_URL=https://your-internal-mirror.example.com/pytorch/cu126
# 3) fallback to PIP_INDEX_URL

# systemd helper
HNM_SERVICE_NAME=hnm-server
HNM_APP_USER=hnm
